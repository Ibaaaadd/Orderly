# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orderly
DB_USER=postgres
DB_PASSWORD=your_password_here

# CORS — frontend URL
CORS_ORIGIN=http://localhost:3000

# Payment gateway: mock | midtrans | xendit
PAYMENT_GATEWAY=mock

# Midtrans (only needed if PAYMENT_GATEWAY=midtrans)
MIDTRANS_SERVER_KEY=SB-Mid-server-YOUR_KEY_HERE

# Xendit (only needed if PAYMENT_GATEWAY=xendit)
XENDIT_API_KEY=xnd_development_YOUR_KEY_HERE
XENDIT_CALLBACK_TOKEN=YOUR_CALLBACK_TOKEN_HERE
XENDIT_CALLBACK_URL=https://your-domain.com/api/payments/webhook
